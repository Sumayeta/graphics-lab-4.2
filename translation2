#include <GL/glut.h>
#include <stdio.h>

float tx, ty;   // Translation
float angle;    // Rotation
float scale;    // Scaling

void display() {
    glClear(GL_COLOR_BUFFER_BIT);
    glLoadIdentity();

    // Apply transformation (user input)
    glTranslatef(tx, ty, 0);
    glRotatef(angle, 0, 0, 1);
    glScalef(scale, scale, 1);

    // Triangle
    glBegin(GL_TRIANGLES);
        glColor3f(1, 0, 0);
        glVertex2f(0, 0.5);
        glVertex2f(-0.5, -0.5);
        glVertex2f(0.5, -0.5);
    glEnd();

    glFlush();
}

int main(int argc, char** argv) {

    // 🔹 User Input
    printf("Enter Translation (tx ty): ");
    scanf("%f %f", &tx, &ty);

    printf("Enter Rotation angle: ");
    scanf("%f", &angle);

    printf("Enter Scaling factor: ");
    scanf("%f", &scale);

    glutInit(&argc, argv);
    glutCreateWindow("User Input Transformation");
    glutInitWindowSize(500, 500);
    gluOrtho2D(-2, 2, -2, 2);

    glutDisplayFunc(display);

    glutMainLoop();
    return 0;
}
