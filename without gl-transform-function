#include <GL/glut.h>
#include <math.h>
#include <stdio.h>

float tx = 0, ty = 0;
float angle = 0;
float scale = 1;

int shape;

// 🔴 Manual Transformation function
void transform(float &x, float &y) {

    // Scaling
    x = x * scale;
    y = y * scale;

    // Rotation
    float rad = angle * 3.1416 / 180;
    float xr = x * cos(rad) - y * sin(rad);
    float yr = x * sin(rad) + y * cos(rad);

    // Translation
    x = xr + tx;
    y = yr + ty;
}

void display() {
    glClear(GL_COLOR_BUFFER_BIT);

    // 🔷 Triangle
    if(shape == 1) {
        float x1=0, y1=0.5;
        float x2=-0.5, y2=-0.5;
        float x3=0.5, y3=-0.5;

        transform(x1,y1);
        transform(x2,y2);
        transform(x3,y3);

        glBegin(GL_TRIANGLES);
            glColor3f(1,0,0);
            glVertex2f(x1,y1);
            glVertex2f(x2,y2);
            glVertex2f(x3,y3);
        glEnd();
    }

    // 🔷 Square
    else if(shape == 2) {
        float x[4] = {-0.5, 0.5, 0.5, -0.5};
        float y[4] = {0.5, 0.5, -0.5, -0.5};

        for(int i=0;i<4;i++)
            transform(x[i], y[i]);

        glBegin(GL_QUADS);
            glColor3f(0,0,1);
            for(int i=0;i<4;i++)
                glVertex2f(x[i], y[i]);
        glEnd();
    }

    // 🔷 Circle
    else if(shape == 3) {
        glBegin(GL_TRIANGLE_FAN);
            glColor3f(0,1,0);

            float cx=0, cy=0;
            transform(cx, cy);
            glVertex2f(cx, cy);

            for(int i=0;i<=100;i++) {
                float a = 2 * 3.1416 * i / 100;
                float x = cos(a)*0.5;
                float y = sin(a)*0.5;

                transform(x,y);
                glVertex2f(x,y);
            }
        glEnd();
    }

    glFlush();
}

void keyboard(unsigned char key, int x, int y) {
    switch(key) {
        case 'a': tx -= 0.1; break;
        case 'd': tx += 0.1; break;
        case 'w': ty += 0.1; break;
        case 's': ty -= 0.1; break;
        case 'r': angle += 10; break;
        case '+': scale += 0.1; break;
        case '-': scale -= 0.1; break;
    }
    glutPostRedisplay();
}

int main(int argc, char** argv) {

    printf("Select Shape:\n1=Triangle\n2=Square\n3=Circle\n");
    scanf("%d", &shape);

    glutInit(&argc, argv);
    glutCreateWindow("Manual Transformation");
    glutInitWindowSize(500, 500);
    gluOrtho2D(-2, 2, -2, 2);

    glutDisplayFunc(display);
    glutKeyboardFunc(keyboard);

    glutMainLoop();
    return 0;
}
